# ============================================
# OAuth2 Boilerplate - Environment Variables
# ============================================
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=oauth2_boilerplate
MYSQL_USERNAME=root
MYSQL_PASSWORD=root1234

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
# 반드시 32자 이상의 랜덤 문자열로 변경하세요
JWT_SECRET=change-me-to-a-random-256-bit-secret-key-at-least-32-chars

# --- Google OAuth2 ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/callback/google

# --- Kakao OAuth2 ---
# https://developers.kakao.com/console/app
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8080/api/auth/callback/kakao

# --- Naver OAuth2 ---
# https://developers.naver.com/apps
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:8080/api/auth/callback/naver

# --- SSAFY OAuth2 ---
# https://project.ssafy.com > [내 어플리케이션] > [서비스 설정] > [SSAFY 로그인]
SSAFY_CLIENT_ID=your-ssafy-client-id
SSAFY_CLIENT_SECRET=your-ssafy-client-secret
SSAFY_REDIRECT_URI=http://localhost:8080/api/auth/callback/ssafy

# --- GitHub OAuth2 ---
# https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/callback/github
